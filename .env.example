# baha 執行時所需的環境變數範本。
# 使用方式：複製為 .env 後依需求修改；.env 不會被納入版控（見 .gitignore）。

# --- MariaDB 連線設定 ---
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=baha
DB_USER=baha
DB_PASSWORD=changeme

# MariaDB root 密碼（僅 docker compose 啟動 mariadb service 使用）
DB_ROOT_PASSWORD=rootchangeme

# --- 日誌設定 ---
# 可選值：DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
