# baha 執行時所需的環境變數範本。
# 使用方式：複製為 .env 後依需求修改；.env 不會被納入版控（見 .gitignore）。

# --- MariaDB 連線設定 ---
# DB_HOST / DB_PORT 為 app container 連線 MariaDB 所用；走 compose 內部網路，
# 因此預設為 service 名稱 mariadb 與 container 內的 3306，與下方 host 綁定無關。
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=baha
DB_USER=baha
DB_PASSWORD=changeme

# MariaDB root 密碼（僅 docker compose 啟動 mariadb service 使用）
DB_ROOT_PASSWORD=rootchangeme

# MariaDB 對宿主機暴露的 port；供宿主直接連 DB 除錯使用。
# 預設 3307，避免與宿主機上其他常駐 MariaDB/MySQL（多佔 3306）衝突。
# 可依需求改為其他未被占用的 port；app 之間不受此值影響。
MARIADB_HOST_PORT=3307

# --- 日誌設定 ---
# 可選值：DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
